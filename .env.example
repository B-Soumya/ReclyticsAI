# ReclyticsAI — API Keys
# Copy this file to .env and fill in the keys you need.
# Only one provider is required at a time.

# Groq (free at https://console.groq.com)
GROQ_API_KEY=

# Google Gemini (free at https://aistudio.google.com)
GEMINI_API_KEY=

# HuggingFace Inference API (free at https://huggingface.co/settings/tokens)
HF_API_KEY=
